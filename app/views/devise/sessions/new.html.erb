<% content_for :title, "Entrar no Lavix" %>

<div class="max-w-md mx-auto card-accent">
  <div class="mb-6 text-center">
    <h2 class="text-2xl">Bem-vindo de volta</h2>
    <p class="text-sm text-ink-200 mt-1">Entre para continuar controlando suas finanças.</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input", required: true %>
    </div>

    <div>
      <%= f.label :password, class: "form-label" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-input", required: true %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="text-sm">
        <label class="inline-flex items-center gap-2 text-ink-100">
          <%= f.check_box :remember_me, class: "rounded bg-ink-700 border-ink-500 text-neon-500 focus:ring-neon-500" %>
          Lembrar de mim
        </label>
      </div>
    <% end %>

    <%= f.submit "Entrar", class: "btn-primary w-full" %>
  <% end %>

  <div class="mt-6 text-center text-sm text-ink-200">
    Novo por aqui? <%= link_to "Criar conta", new_registration_path(resource_name), class: "link-neon" %>
  </div>
</div>
