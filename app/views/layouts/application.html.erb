<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Lavix" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#0B0B0F">
    <%= favicon_link_tag "logo.png" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex flex-col">
    <%= render "shared/navbar" %>

    <main class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-8 flex-1">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <footer class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 py-6 text-xs text-ink-300 border-t border-ink-700 mt-8">
      <div class="flex items-center justify-between">
        <span>&copy; <%= Date.current.year %> <span class="text-neon-400 font-semibold">Lavix</span>. Feito para decisões rápidas.</span>
        <span class="hidden sm:block text-ink-400">v1.0</span>
      </div>
    </footer>
  </body>
</html>
