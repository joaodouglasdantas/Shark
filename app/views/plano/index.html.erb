<% content_for :title, "Plano Financeiro — Lavix" %>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-3xl">Plano Financeiro</h1>
    <p class="text-ink-200 text-sm mt-1">Análise inteligente das suas finanças · <%= I18n.l(Date.current, format: "%B de %Y").capitalize %></p>
  </div>
  <%= link_to "Novo lançamento", new_transaction_path, class: "btn-primary self-start" %>
</div>

<% if @has_data %>

  <div class="grid gap-4 grid-cols-2 lg:grid-cols-3 mb-8">

    <%
      score_pct         = @health_score.clamp(0, 100)
      score_color       = score_pct >= 70 ? '#4ade80' : score_pct >= 40 ? '#eab308' : '#f87171'
      positive_months   = (1..3).count do |offset|
        m = Date.current.beginning_of_month - offset.months
        txn = current_user.transactions.in_range(m..m.end_of_month)
        txn.income.sum(:amount) > txn.expenses.sum(:amount)
      end
      categories_bonus  = [current_user.transactions.expenses
                             .in_range(3.months.ago..Date.current)
                             .distinct.count(:category_id) * 2, 10].min
      high_growth_count = @trends.count { |t| t[:delta] && t[:delta] > 20 }
      penalty           = high_growth_count * 5
    %>

    <div class="card-accent flex flex-col col-span-2 lg:col-span-3">
      <div class="card-title mb-3">Score financeiro</div>

      <div class="flex items-end gap-2">
        <span class="text-5xl font-bold" style="color: <%= score_color %>"><%= @health_score %></span>
        <span class="text-ink-400 text-sm mb-1">/100</span>
      </div>

      <div class="mt-4">
        <div class="relative w-full h-1.5 rounded-full overflow-hidden">
          <div class="absolute inset-0" style="background: linear-gradient(to right, #ef4444 0%, #eab308 40%, #eab308 70%, #4ade80 100%); opacity: 0.2;"></div>
          <div class="absolute inset-0" style="background: linear-gradient(to right, #ef4444 0%, #eab308 40%, #eab308 70%, #4ade80 100%); clip-path: inset(0 <%= 100 - score_pct %>% 0 0 round 9999px);"></div>
        </div>
        <div class="relative -mt-2 h-4 pointer-events-none">
          <div class="absolute w-3 h-3 rounded-full border-2 border-ink-900 shadow"
               style="left: calc(<%= score_pct %>% - 6px); background-color: <%= score_color %>;"></div>
        </div>
        <div class="relative mt-2 h-3">
          <div class="absolute w-px h-2 bg-ink-600" style="left: 40%;"></div>
          <div class="absolute w-px h-2 bg-ink-600" style="left: 70%;"></div>
        </div>
        <div class="relative flex text-xs mt-0.5 text-ink-400">
          <span style="width:40%">Ruim</span>
          <span style="width:30%;text-align:center">Regular</span>
          <span style="width:30%;text-align:right">Bom</span>
        </div>
      </div>

      <p class="text-xs text-ink-300 mt-3">
        <%= score_pct >= 70 ? "Saúde financeira boa" : score_pct >= 40 ? "Pode melhorar" : "Atenção necessária" %>
      </p>

      <details class="score-details mt-4 pt-6 border-t border-ink-700">
        <summary class="score-details-summary link-neon text-xs font-medium
                 focus:no-underline active:no-underline focus-visible:outline-none">
          Como funciona?
        </summary>

        <div class="mt-4 space-y-4 text-xs">

          <div class="space-y-1.5">
            <p class="text-ink-400 font-semibold uppercase tracking-widest mb-2">Como o score é formado</p>

            <div class="flex justify-between items-start gap-3 py-2 border-b border-ink-700">
              <div>
                <p class="text-ink-100 font-medium">Ponto de partida</p>
                <p class="text-ink-400 mt-0.5">Todo usuário começa com 50 pontos.</p>
              </div>
              <span class="font-mono font-semibold text-ink-300 whitespace-nowrap">+50 pts</span>
            </div>

            <div class="flex justify-between items-start gap-3 py-2 border-b border-ink-700">
              <div>
                <p class="text-ink-100 font-medium">Meses no azul</p>
                <p class="text-ink-400 mt-0.5">
                  Cada mês dos últimos 3 em que receitas &gt; gastos vale +10 pts.
                  Você teve <span class="text-ink-200 font-semibold"><%= positive_months %>/3</span> meses positivos.
                </p>
              </div>
              <span class="font-mono font-semibold whitespace-nowrap <%= positive_months > 0 ? 'text-emerald-400' : 'text-ink-400' %>">
                +<%= positive_months * 10 %> pts
              </span>
            </div>

            <div class="flex justify-between items-start gap-3 py-2 border-b border-ink-700">
              <div>
                <p class="text-ink-100 font-medium">Organização</p>
                <p class="text-ink-400 mt-0.5">Cada categoria usada nos últimos 3 meses vale +2 pts (máx. +10).</p>
              </div>
              <span class="font-mono font-semibold whitespace-nowrap <%= categories_bonus > 0 ? 'text-emerald-400' : 'text-ink-400' %>">
                +<%= categories_bonus %> pts
              </span>
            </div>

            <div class="flex justify-between items-start gap-3 py-2">
              <div>
                <% if high_growth_count > 0 %>
                  <p class="text-red-300 font-medium">Gastos em alta (<%= high_growth_count %> categoria<%= high_growth_count > 1 ? 's' : '' %>)</p>
                  <p class="text-ink-400 mt-0.5">Categoria com crescimento &gt;20% vs. mês anterior penaliza em −5 pts cada.</p>
                <% else %>
                  <p class="text-emerald-300 font-medium">Gastos sob controle</p>
                  <p class="text-ink-400 mt-0.5">Nenhuma categoria com crescimento acima de 20%.</p>
                <% end %>
              </div>
              <span class="font-mono font-semibold whitespace-nowrap <%= high_growth_count > 0 ? 'text-red-400' : 'text-emerald-400' %>">
                −<%= penalty %> pts
              </span>
            </div>
          </div>

          <div class="pt-2 border-t border-ink-700 space-y-1.5">
            <p class="text-ink-400 font-semibold uppercase tracking-widest mb-2">Como melhorar</p>
            <p class="text-ink-300 flex gap-2"><span class="text-neon-500 font-bold flex-shrink-0">→</span>Feche cada mês com receitas maiores que gastos (+10 pts/mês).</p>
            <p class="text-ink-300 flex gap-2"><span class="text-neon-500 font-bold flex-shrink-0">→</span>Use categorias em todos os lançamentos (até +10 pts).</p>
            <p class="text-ink-300 flex gap-2"><span class="text-neon-500 font-bold flex-shrink-0">→</span>Evite que uma categoria cresça mais de 20% num mês (−5 pts cada).</p>
          </div>

        </div>
      </details>

    </div>

    <div class="card">
      <div class="card-title">Gastos este mês</div>
      <div class="card-value text-red-400"><%= brl(@this_month_expense) %></div>
      <p class="text-xs text-ink-200 mt-2">Receitas: <span class="text-emerald-400"><%= brl(@this_month_income) %></span></p>
    </div>

    <div class="card">
      <div class="card-title">Previsão próximo mês</div>
      <div class="card-value text-neon-400"><%= brl(@forecast_total) %></div>
      <p class="text-xs text-ink-200 mt-2">
        Média <%= @forecast_months_available == 1 ? "do último mês" : "dos últimos #{@forecast_months_available} meses" %>
      </p>
    </div>

    <div class="card">
      <div class="card-title">Taxa de economia</div>
      <div class="card-value" style="color: <%= @avg_saving_rate >= 20 ? '#4ade80' : @avg_saving_rate > 0 ? '#eab308' : '#f87171' %>">
        <%= @avg_saving_rate.round(1) %>%
      </div>
      <p class="text-xs text-ink-200 mt-2">
        <%= @saving_rate_months == 0 ? "Sem dados de receita ainda" : "Média #{@saving_rate_months == 1 ? "do último mês" : "dos últimos #{@saving_rate_months} meses"}" %>
      </p>
    </div>
  </div>

  <% if @insights.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-semibold tracking-widest uppercase text-ink-400 mb-4">Insights</h2>
      <div class="grid gap-2 sm:grid-cols-2">
        <% @insights.each do |insight| %>
          <%
            accent = case insight[:type]
                     when :success then "#10b981"
                     when :warning then "#eab308"
                     when :danger  then "#f87171"
                     when :tip     then "#f97316"
                     else               "#6b7280"
                     end
          %>
          <div class="rounded-lg bg-ink-800/40 px-4 py-3" style="border-left: 2px solid <%= accent %>;">
            <p class="text-sm font-semibold text-ink-50"><%= insight[:title] %></p>
            <p class="text-xs text-ink-300 mt-1 leading-relaxed"><%= insight[:body] %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid gap-6 lg:grid-cols-2 mb-8">

    <div class="card">
      <h2 class="card-title mb-4">Maiores gastos do mês</h2>
      <% if @expenses_by_category_month.any? %>
        <%
          chart_data   = @expenses_by_category_month.map { |c| [c[:name], c[:total]] }.to_h
          chart_colors = @expenses_by_category_month.map { |c| c[:color] }
          many_cats    = @expenses_by_category_month.size > PlanoController::BAR_THRESHOLD
          bar_height   = many_cats ? "#{[@expenses_by_category_month.size * 40, 280].max}px" : "280px"
        %>
        <%= bar_chart chart_data,
                      colors: chart_colors,
                      height: bar_height,
                      library: {
                        backgroundColor: "transparent",
                        indexAxis: (many_cats ? "y" : "x"),
                        plugins: { legend: { display: false } },
                        scales: {
                          x: { ticks: { color: "#9CA3AF" }, grid: { color: "#374151" } },
                          y: { ticks: { color: "#F9FAFB" }, grid: { display: !many_cats } }
                        }
                      } %>
      <% else %>
        <p class="text-ink-200 text-sm">Sem despesas registradas neste mês.</p>
      <% end %>
    </div>

    <div class="card">
      <h2 class="card-title mb-4">Previsão por categoria — próximo mês</h2>
      <% if @forecast_next_month.any? %>
        <%
          forecast_data   = @forecast_next_month.map { |c| [c[:name], c[:average]] }.to_h
          forecast_colors = @forecast_next_month.map { |c| c[:color] }
          many_forecast   = @forecast_next_month.size > PlanoController::BAR_THRESHOLD
          forecast_height = many_forecast ? "#{[@forecast_next_month.size * 40, 280].max}px" : "280px"
        %>
        <%= bar_chart forecast_data,
                      colors: forecast_colors,
                      height: forecast_height,
                      library: {
                        backgroundColor: "transparent",
                        indexAxis: (many_forecast ? "y" : "x"),
                        plugins: { legend: { display: false } },
                        scales: {
                          x: { ticks: { color: "#9CA3AF" }, grid: { color: "#374151" } },
                          y: { ticks: { color: "#F9FAFB" }, grid: { display: !many_forecast } }
                        }
                      } %>
      <% else %>
        <p class="text-ink-200 text-sm">Dados insuficientes para previsão (necessário ao menos 1 mês anterior).</p>
      <% end %>
    </div>
  </div>

  <div class="card mb-8">
    <div class="flex items-start justify-between gap-4 mb-1">
      <h2 class="card-title">Evolução de gastos por categoria</h2>
      <% if @evolution_cat_total > PlanoController::EVOLUTION_MAX_CATS %>
        <span class="text-xs text-ink-400 whitespace-nowrap">
          top <%= PlanoController::EVOLUTION_MAX_CATS %> de <%= @evolution_cat_total %> categorias
        </span>
      <% end %>
    </div>
    <p class="text-xs text-ink-400 mb-4">Valor gasto por mês em cada categoria</p>
    <% if @evolution_by_cat.any? %>
      <%
        chart_series = @evolution_by_cat.map { |cat| { name: cat[:name], data: cat[:data] } }
        chart_colors = @evolution_by_cat.map { |c| c[:color] }
      %>
      <%= line_chart chart_series,
                    colors: chart_colors,
                    height: "300px",
                    library: { backgroundColor: "transparent" } %>
    <% else %>
      <p class="text-ink-400 text-sm">Nenhuma despesa registrada ainda.</p>
    <% end %>
  </div>

  <% if @trends.any? %>
    <div class="card p-0 overflow-hidden mb-8">
      <div class="px-5 py-4 border-b border-ink-700">
        <h2 class="card-title">Tendências por categoria</h2>
        <p class="text-xs text-ink-200 mt-1">Comparando último mês com o mês anterior</p>
      </div>
      <div class="table-scroll-wrapper">
        <table class="table" style="min-width: 520px;">
          <colgroup>
            <col>
            <col style="width:130px">
            <col style="width:130px">
            <col style="width:110px">
          </colgroup>
          <thead>
            <tr>
              <th>Categoria</th>
              <th class="text-right">Mês anterior</th>
              <th class="text-right">Último mês</th>
              <th class="text-right">Variação</th>
            </tr>
          </thead>
          <tbody>
            <% @trends.each do |trend| %>
              <tr>
                <td class="cell-truncate-flex">
                  <div class="inner">
                    <span class="dot flex-shrink-0" style="background-color: <%= @category_colors_map[trend[:name]] || '#6B7280' %>;"></span>
                    <span class="font-medium" title="<%= trend[:name] %>"><%= trend[:name] %></span>
                  </div>
                </td>
                <td class="text-right font-mono text-ink-200 whitespace-nowrap"><%= brl(trend[:prev_month]) %></td>
                <td class="text-right font-mono text-ink-50 whitespace-nowrap"><%= brl(trend[:last_month]) %></td>
                <td class="text-right font-mono whitespace-nowrap">
                  <% if trend[:delta].nil? %>
                    <span class="text-ink-200 text-xs">novo</span>
                  <% elsif trend[:delta] > 0 %>
                    <span class="text-red-400">↑ <%= trend[:delta] %>%</span>
                  <% elsif trend[:delta] < 0 %>
                    <span class="text-emerald-400">↓ <%= trend[:delta].abs %>%</span>
                  <% else %>
                    <span class="text-ink-200">= 0%</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if @forecast_next_month.any? %>
    <div class="card p-0 overflow-hidden">
      <div class="px-5 py-4 border-b border-ink-700">
        <h2 class="card-title">Previsão detalhada — próximo mês</h2>
        <p class="text-xs text-ink-200 mt-1">Baseada na média <%= @forecast_months_available == 1 ? "do último mês" : "dos últimos #{@forecast_months_available} meses" %> por categoria</p>
      </div>
      <div class="table-scroll-wrapper">
        <table class="table" style="min-width: 400px;">
          <colgroup>
            <col>
            <col style="width:120px">
            <col style="width:100px">
          </colgroup>
          <thead>
            <tr>
              <th>Categoria</th>
              <th class="text-right">Previsão</th>
              <th class="text-right">% do total</th>
            </tr>
          </thead>
          <tbody>
            <% @forecast_next_month.each do |cat| %>
              <tr>
                <td class="cell-truncate-flex">
                  <div class="inner">
                    <span class="dot flex-shrink-0" style="background-color: <%= cat[:color] %>;"></span>
                    <span title="<%= cat[:name] %>"><%= cat[:name] %></span>
                  </div>
                </td>
                <td class="text-right font-mono text-neon-400 whitespace-nowrap"><%= brl(cat[:average]) %></td>
                <td class="text-right font-mono text-ink-200 whitespace-nowrap">
                  <%= @forecast_total > 0 ? "#{(cat[:average] / @forecast_total * 100).round(1)}%" : "—" %>
                </td>
              </tr>
            <% end %>
            <tr class="border-t border-ink-600">
              <td class="font-semibold text-ink-50">Total previsto</td>
              <td class="text-right font-mono font-semibold text-neon-400 whitespace-nowrap"><%= brl(@forecast_total) %></td>
              <td class="text-right font-mono text-ink-200">100%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>


<% else %>
  <div class="card-accent text-center py-20">
    <h2 class="text-2xl mb-2">Sem dados ainda</h2>
    <p class="text-ink-200 mb-6 max-w-md mx-auto">
      Cadastre seus lançamentos para que o plano financeiro possa gerar análises, previsões e insights personalizados.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <%= link_to "Criar categoria", new_category_path, class: "btn-primary" %>
      <%= link_to "Novo lançamento", new_transaction_path, class: "btn-secondary" %>
    </div>
  </div>
<% end %>
