<div class="card max-w-xl">
  <%= form_with model: transaction, class: "space-y-5" do |f| %>
    <% if transaction.errors.any? %>
      <div class="flash-alert">
        <strong><%= pluralize(transaction.errors.count, "erro") %> ao salvar:</strong>
        <ul class="list-disc list-inside mt-2 text-sm">
          <% transaction.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :kind, "Tipo", class: "form-label" %>
      <div class="grid grid-cols-2 gap-3">
        <label class="cursor-pointer">
          <%= f.radio_button :kind, "expense", class: "peer sr-only" %>
          <div class="rounded-lg border border-ink-500 bg-ink-700 px-4 py-3 text-center text-sm font-medium
                      peer-checked:border-red-500 peer-checked:bg-red-500/10 peer-checked:text-red-300">
            Despesa
          </div>
        </label>
        <label class="cursor-pointer">
          <%= f.radio_button :kind, "income", class: "peer sr-only" %>
          <div class="rounded-lg border border-ink-500 bg-ink-700 px-4 py-3 text-center text-sm font-medium
                      peer-checked:border-emerald-500 peer-checked:bg-emerald-500/10 peer-checked:text-emerald-300">
            Receita
          </div>
        </label>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :amount, "Valor (R$)", class: "form-label" %>
        <%= f.number_field :amount, class: "form-input", step: "0.01", min: "0.01", required: true, autofocus: true, placeholder: "0,00" %>
      </div>
      <div>
        <%= f.label :date, "Data", class: "form-label" %>
        <%= f.date_field :date, class: "form-input", required: true %>
      </div>
    </div>

    <div>
      <%= f.label :category_id, "Categoria", class: "form-label" %>
      <%= f.collection_select :category_id, current_user.categories.alphabetical, :id, :name,
            { prompt: "Selecione uma categoria" }, class: "form-select", required: true %>
    </div>

    <div>
      <%= f.label :description, "Descrição (opcional)", class: "form-label" %>
      <%= f.text_field :description, class: "form-input", maxlength: 120, placeholder: "Ex.: Almoço com a equipe" %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Salvar", class: "btn-primary" %>
      <%= link_to "Cancelar", transactions_path, class: "btn-ghost" %>
    </div>
  <% end %>
</div>
