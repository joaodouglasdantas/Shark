<div class="card max-w-xl">
  <%= form_with model: category, class: "space-y-5" do |f| %>
    <% if category.errors.any? %>
      <div class="flash-alert">
        <strong><%= pluralize(category.errors.count, "erro") %> ao salvar:</strong>
        <ul class="list-disc list-inside mt-2 text-sm">
          <% category.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-input", autofocus: true, required: true, placeholder: "Ex.: Alimentação" %>
    </div>

    <div>
      <%= f.label :color, class: "form-label" %>
      <div class="flex items-center gap-3" data-controller="color-picker">
        <%= f.color_field :color,
              class: "h-12 w-16 rounded-lg bg-ink-700 border border-ink-500 cursor-pointer",
              data: { color_picker_target: "picker", action: "input->color-picker#pickerChanged" } %>
        <%= f.text_field :color,
              class: "form-input font-mono",
              pattern: "#[0-9A-Fa-f]{6}",
              placeholder: "#FF6B00",
              maxlength: 7,
              data: { color_picker_target: "text", action: "input->color-picker#textChanged" } %>
      </div>
      <p class="form-hint">Use o seletor ou digite o código hexadecimal (#RRGGBB).</p>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Salvar", class: "btn-primary" %>
      <%= link_to "Cancelar", categories_path, class: "btn-ghost" %>
    </div>
  <% end %>
</div>
